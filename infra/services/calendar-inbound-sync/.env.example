# /opt/matrix-calendar-inbound/.env
# Mode 0600, owner matrix-bridge:matrix-bridge.

# Direkter Postgres-Connect — pg_notify LISTEN braucht keinen Pool und
# auch keine PostgREST-Schicht. User 'postgres' reicht; pgcrypto-Decryption
# in den service-role-RPCs (get_external_calendar_credentials etc.) laeuft
# als SECURITY DEFINER und liest app.ai_master_key automatisch.
DATABASE_URL=postgresql://postgres@127.0.0.1:5432/postgres

# Bind-Adresse + Port (nginx routet localhost-only).
HOST=127.0.0.1
PORT=8083

# Cron-Tick (ms) fuer Polling-Calendars. 60s = granular genug fuer
# minimale sync_interval_minutes=5 ohne CPU-Verschwendung.
CRON_TICK_MS=60000
