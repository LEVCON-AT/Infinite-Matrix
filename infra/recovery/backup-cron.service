[Unit]
Description=Matrix daily local snapshot (Postgres + Storage + Bridge)
Documentation=file:///opt/matrix-repo/infra/recovery/README.md
Wants=docker.service
After=docker.service

# Failure-Notification: mailx an admin@levcon.at, falls vorhanden.
# Wenn mailx fehlt: kein zusaetzlicher Fehler, nur Eintrag im journal.
# OnFailure gehoert in [Unit], nicht [Service].
OnFailure=backup-failure-notify@%n.service

[Service]
Type=oneshot
User=root
Group=root

# Skript bricht eigenstaendig ab bei Fehler (set -euo pipefail).
ExecStart=/opt/recovery/scripts/backup-now.sh

# Sollte nie ueber 30 Min brauchen — wenn doch, Bug.
TimeoutStartSec=30min

# Skripte schreiben mit logger -t matrix-recovery → journald.
StandardOutput=journal
StandardError=journal
SyslogIdentifier=matrix-backup

[Install]
WantedBy=multi-user.target
