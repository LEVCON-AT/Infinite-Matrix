############################################################
# Matrix Supabase .env — TEMPLATE
#
# Nach Ausfuellen kopieren: cp .env.example .env
# Private Daten — niemals committen.
#
# Pflicht-Felder sind mit [TODO] markiert. Der Rest hat
# Defaults die meistens passen.
############################################################

# ─── Postgres ─────────────────────────────────────────────
# [TODO] 32+ Zeichen, gross/klein/Zahl/Sonder. Empfehlung:
#   openssl rand -base64 32
POSTGRES_PASSWORD=DEIN_LANGES_ZUFALLSPASSWORT_HIER
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ─── JWT / Supabase-Keys ─────────────────────────────────
# JWT_SECRET: Base fuer alle Tokens. 32+ Zeichen.
#   openssl rand -base64 40
# [TODO]
JWT_SECRET=DEIN_JWT_SECRET_40_ZEICHEN_HIER
JWT_EXPIRY=3600

# ANON_KEY + SERVICE_ROLE_KEY werden aus JWT_SECRET erzeugt.
# Verwende dazu infra/scripts/supabase-genkeys.sh — das Script
# gibt dir die beiden fertig generierten JWTs aus.
# [TODO] beide nach supabase-genkeys.sh ausfuellen
ANON_KEY=
SERVICE_ROLE_KEY=

# Phoenix-Secret fuer Realtime (64 Zeichen hex).
#   openssl rand -hex 32
# [TODO]
SECRET_KEY_BASE=

# ─── AI-Master-Key (Migration 018) ────────────────────────
# Postgres-GUC `app.ai_master_key` — wird von _ai_master_key()
# RPC erwartet, encrypted user_ai_providers.api_key_encrypted via
# pgp_sym_encrypt damit. Mindestens 16 Zeichen, sonst RAISE.
#   openssl rand -base64 32
# [TODO] Setzen via:
#   docker compose exec db psql -U postgres -d postgres -c \
#     "ALTER DATABASE postgres SET app.ai_master_key = '${AI_MASTER_KEY}'"
#   Anschliessend Postgres-Container restart, damit die Session-GUC
#   neu gelesen wird. Ohne diesen Step schlagen alle AI-Provider-Calls
#   mit `ai_master_key_missing` fehl.
AI_MASTER_KEY=

# ─── Site-URL ─────────────────────────────────────────────
# Die oeffentliche URL, unter der der Client laeuft.
# Muss exakt mit der nginx-Domain uebereinstimmen.
SITE_URL=https://staging.matrix.levcon.at
API_EXTERNAL_URL=https://staging.matrix.levcon.at
ADDITIONAL_REDIRECT_URLS=https://staging.matrix.levcon.at/**,http://localhost:5173/**

# ─── Features ─────────────────────────────────────────────
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

# ─── SMTP (Ionos) ─────────────────────────────────────────
# [TODO] Ionos-Mail-Accounts — Adresse + Passwort aus Ionos-Panel
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=noreply@levcon.at
SMTP_PASS=DEIN_IONOS_MAIL_PASSWORT
SMTP_ADMIN_EMAIL=noreply@levcon.at
SMTP_SENDER_NAME=Matrix

# ─── OAuth-Provider (spaeter aktivieren) ─────────────────
# Zuerst bei Google Cloud Console OAuth-Client registrieren,
# Redirect-URI: https://staging.matrix.levcon.at/auth/v1/callback
ENABLE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn: https://www.linkedin.com/developers/apps
# Produkt "Sign In with LinkedIn using OpenID Connect" aktivieren
ENABLE_LINKEDIN_OAUTH=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Kong (API-Gateway-Ports, nur lokal binden) ──────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ─── Studio (Admin-UI) ────────────────────────────────────
# HTTP-Basic-Auth vor Kong-Studio-Route.
# [TODO] Starkes Passwort
DASHBOARD_USERNAME=matrix
DASHBOARD_PASSWORD=DEIN_STUDIO_ADMIN_PASSWORT
STUDIO_DEFAULT_ORGANIZATION=Matrix
STUDIO_DEFAULT_PROJECT=Staging

# ─── Docker / System ─────────────────────────────────────
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
