# Supabase-Public-Werte (duerfen ins Frontend — RLS schuetzt die Daten).
# URL zeigt auf Kong/nginx, nicht direkt auf PostgREST.
VITE_SUPABASE_URL=https://staging.matrix.levcon.at
VITE_SUPABASE_ANON_KEY=<JWT_ANON_KEY_HIER_EINFUEGEN>

# Public Site-URL fuer Magic-Link-Redirect (ASVS V2.1.4 — Redirect-URI
# muss validiert/whitelisted sein). Der Wert wird auch in Supabase-Auth-
# Allowlist eingetragen — einfach 1:1 dieselbe Origin.
VITE_SITE_URL=https://staging.matrix.levcon.at/
