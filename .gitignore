!infra/supabase/volumes/logs/
!infra/supabase/volumes/logs/**

# --- Supabase Runtime-Volumes (Bind-Mounts mit Live-Daten) ---
# CRITICAL: enthaelt Postgres-Datendateien + Storage-Uploads. Niemals
# committen, niemals durch `git clean` wegputzen. .gitignore + die
# zielgerichtete Cleanup-Logik im deploy.yml halten das.
infra/supabase/volumes/db/data/
infra/supabase/volumes/storage/
infra/supabase/volumes/functions/

# --- Runtime ---
.pids/

# misc
Secrets_aus_claude_chat.txt
.playwright-mcp/

# --- Lokale One-Off Diagnose-/Migrations-Scripts ---
# Repo-root scripts/ enthaelt Ad-hoc .sh-Helper + commit-msg-*.txt
# Artefakte (apply-mig-*, check-pgpw-*, diagnose-*, ...) — nicht
# versionierter Werkzeugkasten. Falls ein Script langfristig gehoert,
# bewusst in infra/ oder packages/<x>/scripts/ verschieben.
/scripts/

# --- Debug-Screenshots (Root-only) ---
# Agent-Artefakte (hyperui-*.png, tree-*.png, card-overlay-*.png, etc.).
# /*.png matcht nur das Repo-Root — Asset-PNGs in packages/ bleiben tracked.
/*.png
